# Non-interactive shells get no config
[[ $- != *i* ]] && return

# ── Exports ───────────────────────────────────────────────────────────────────
export LANG=en_US.UTF-8
export EDITOR='nano'
typeset -U path PATH

# ── History ───────────────────────────────────────────────────────────────────
HISTSIZE=5000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory sharehistory
setopt hist_ignore_space hist_ignore_all_dups hist_save_no_dups hist_find_no_dups

# ── Options ───────────────────────────────────────────────────────────────────
setopt extendedglob nomatch notify completealiases always_to_end complete_in_word nocorrect
unsetopt AUTO_CD
bindkey -e

# ── Completion styles (defined before compinit runs via zinit) ────────────────
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'

# ── zinit bootstrap ───────────────────────────────────────────────────────────
ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
[[ ! -d $ZINIT_HOME/.git ]] && mkdir -p "${ZINIT_HOME:h}" && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# ── Prompt (sync — must be ready before first prompt) ─────────────────────────
zinit ice as"command" from"github-rel" \
          atclone"./starship init zsh > init.zsh; ./starship completions zsh > _starship" \
          atpull"%atclone" src"init.zsh"
zinit light starship/starship

# ── Core CLI tools (sync — aliased immediately) ───────────────────────────────
zinit ice from"gh-r" as"program"
zinit load junegunn/fzf
eval "$(fzf --zsh)"

zinit ice from"gh-r" as"program"
zinit load eza-community/eza

zinit ice from"gh-r" as"program" mv"bat* -> bat" pick"bat/bat"
zinit load sharkdp/bat

# ── Zsh plugins (sync — keybinding widgets must be registered before first prompt)
zinit load zdharma-continuum/history-search-multi-word

# ── Zsh plugins (async) ───────────────────────────────────────────────────────

# Syntax highlighting — must be last plugin; triggers cached compinit via atinit
zinit ice wait lucid atinit"ZINIT[COMPINIT_OPTS]=-C; zpcompinit; zpcdreplay"
zinit load zdharma-continuum/fast-syntax-highlighting

zinit ice wait lucid
zinit load hlissner/zsh-autopair

# LS_COLORS — reset prevents color bleed from prior atclone runs
zinit ice wait"0c" lucid reset \
    atclone"local P=${${(M)OSTYPE:#*darwin*}:+g}
            \${P}sed -i \
            '/DIR/c\DIR 38;5;63;1' LS_COLORS; \
            \${P}dircolors -b LS_COLORS > c.zsh" \
    atpull'%atclone' pick"c.zsh" nocompile'!' \
    atload='zstyle ":completion:*" list-colors ${(s.:.)LS_COLORS}'
zinit load trapd00r/LS_COLORS

zinit ice wait lucid atload"!_zsh_autosuggest_start"
zinit load zsh-users/zsh-autosuggestions

zinit ice wait lucid
zinit load zsh-users/zsh-completions

zinit ice wait lucid
zinit load Aloxaf/fzf-tab

zinit ice wait lucid from"gh-r" as"program" atload"{ tldr --update } > /dev/null 2>&1 &!"
zinit load tldr-pages/tlrc

zinit cdreplay -q

# ── Keybindings ───────────────────────────────────────────────────────────────
bindkey "^F" history-search-multi-word
bindkey "^N" history-search-backward
bindkey "^P" history-search-forward

# ── Aliases ───────────────────────────────────────────────────────────────────
alias ls='eza --all --long --icons=always --group-directories-first --header --octal-permissions'
alias cat='bat --theme "Solarized (dark)" --tabs 4 --style full'

# ── Functions ─────────────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "linux" -}}
get_wireless_ip() {
  interface=$(iw dev 2>/dev/null | awk '$1=="Interface"{print $2}' || nmcli device status 2>/dev/null | awk '$2=="wifi" {print $1}')
  if [[ -n "$interface" ]]; then
    ip=$(ip -4 -o addr show "$interface" | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
    [[ -n "$ip" ]] && echo "$ip" || echo "?"
  else
    echo ""
  fi
}
{{ else if eq .chezmoi.os "darwin" -}}
get_wireless_ip() {
  interface=$(networksetup -listallhardwareports 2>/dev/null | awk '/Wi-Fi|AirPort/{getline; print $2}')
  if [[ -n "$interface" ]]; then
    ip=$(ipconfig getifaddr "$interface")
    [[ -n "$ip" ]] && echo "$ip" || echo "?"
  else
    echo ""
  fi
}
{{ end -}}

ip-internal() echo "Wireless :: IP => $( get_wireless_ip )"
ip-external() echo "External :: IP => $( curl --silent https://ifconfig.me )"
ipinfo() { ip-internal && ip-external }

# ── macOS ─────────────────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"

{{ end -}}
# ── Tmux ──────────────────────────────────────────────────────────────────────
[[ -d ~/.tmux/plugins/tpm && -f ~/.tmux.conf ]] && \
  ~/.tmux/plugins/tpm/bin/install_plugins > /dev/null 2>&1
[[ -z "$TMUX" ]] && tmux new-session -A -s main
