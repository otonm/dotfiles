font-family = FiraCode Nerd Font Mono
font-feature = calt, cv02, cv06, cv15, cv16, cv30, ordn, salt, ss03
font-size = 12
font-thicken = 0
theme = Catppuccin Mocha
minimum-contrast = 1.5
background-opacity = 0.95
background-opacity-cells = true
background-blur = 20
window-height = 50
window-width = 200
